<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Announcements - Jelly Jump </title>
    <link rel="stylesheet" href="/style/globalstyle.css">
    <link rel="stylesheet" href="/style/announcement.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="announcement-wrapper">
        <h1>📜 Announcements</h1>

        <!-- creating announcements -->
        <% if (user && (user.role === 'admin' || user.role === "sysadmin")) { %>
            <div class="create-form">
                <h2>Create Announcement</h2>
                <form action="/announcement/createAnnouncement" method="post">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input type="text" name="title" id="title" required maxlength="100">
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea name="message" id="message" rows="4" required maxlength="1000"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="urgency">Urgency</label>
                            <select name="urgency" id="urgency">
                                <option value="low">Low</option>
                                <option value="medium">Medium</option>
                                <option value="high">High</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="datePosted">Post Date</label>
                            <input type="datetime-local" name="datePosted" id="datePosted" min="<%= new Date().toISOString().slice(0,16) %>">
                        </div>
                    </div>

                    <div class="form-submit">
                        <button type="submit" class="submit-btn">Post Announcement</button>
                    </div>
                </form>
            </div>
            <hr>
        <% } %>

        <!-- listing announcements -->
        <% if (announcements && announcements.length > 0) { %>
            <% announcements.forEach(a => { %>
                <div class="announcement-card">
                    
                    <span class="posted-date"><%= new Date(a.datePosted).toLocaleString() %></span>
                    <h3><%= a.title %></h3>
                    <p><%= a.message %></p>
                    <span class="urgency-badge urgency-<%= a.urgency %>"><%= a.urgency.charAt(0).toUpperCase() + a.urgency.slice(1) %></span>

                    <% if (user && (user.role === 'admin' || user.role === "sysadmin")) { %>
                        <div class="admin-actions">
                            <form action="/announcement/delete/<%= a._id %>" method="POST">
                                <button type="submit" class="delete-btn">Delete</button>
                            </form>
                            <button class="edit-btn" onclick="document.getElementById('edit-modal-<%= a._id %>').style.display='flex'">Edit</button>
                        </div>

                        <div id="edit-modal-<%= a._id %>" class="modal-overlay" style="display:none;">
                            <div class="modal-card">
                                <h2>Edit Announcement</h2>
                                <form action="/announcement/edit/<%= a._id %>" method="POST">
                                    <label>Title:</label>
                                    <input type="text" name="title" value="<%= a.title %>" maxlength="100">

                                    <label>Message:</label>
                                    <textarea name="message" rows="4" maxlength="1000"><%= a.message %></textarea>

                                    <label>Urgency:</label>
                                    <select name="urgency">
                                        <option value="low" <%= a.urgency === 'low' ? 'selected' : '' %>>Low</option>
                                        <option value="medium" <%= a.urgency === 'medium' ? 'selected' : '' %>>Medium</option>
                                        <option value="high" <%= a.urgency === 'high' ? 'selected' : '' %>>High</option>
                                    </select>

                                    <div class="modal-actions">
                                        <button type="submit" class="submit-btn">Save Changes</button>
                                        <button type="button" class="cancel-btn" onclick="document.getElementById('edit-modal-<%= a._id %>').style.display='none'">Cancel</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } else { %>
            <p>No announcements posted yet.</p>
        <% } %>

        <% if (user && (user.role === 'admin' || user.role === "sysadmin") && scheduled.length > 0) { %>
            <div class="scheduled-section">
                <h2>Scheduled Posts</h2>
                <% scheduled.forEach(a => { %>
                    <div class="announcement-card">
                        <span class="posted-date">Scheduled for: <%= new Date(a.datePosted).toLocaleString() %></span>
                        <h3><%= a.title %></h3>
                        <p><%= a.message %></p>
                        <span class="urgency-badge urgency-<%= a.urgency %>"><%= a.urgency.charAt(0).toUpperCase() + a.urgency.slice(1) %></span>
                        <div class="admin-actions">
                            <form action="/announcement/delete/<%= a._id %>" method="POST">
                                <button type="submit" class="delete-btn">Delete</button>
                            </form>
                            <button class="edit-btn" onclick="document.getElementById('edit-modal-<%= a._id %>').style.display='flex'">Edit</button>
                        </div>
                        <!-- reuse same edit modal -->
                        <div id="edit-modal-<%= a._id %>" class="modal-overlay" style="display:none;">
                            <div class="modal-card">
                                <h2>Edit Announcement</h2>
                                <form action="/announcement/edit/<%= a._id %>" method="POST">
                                    <label>Title:</label>
                                    <input type="text" name="title" value="<%= a.title %>" maxlength="100">
                                    <label>Message:</label>
                                    <textarea name="message" rows="4" maxlength="1000"><%= a.message %></textarea>
                                    <label>Urgency:</label>
                                    <select name="urgency">
                                        <option value="low" <%= a.urgency === 'low' ? 'selected' : '' %>>Low</option>
                                        <option value="medium" <%= a.urgency === 'medium' ? 'selected' : '' %>>Medium</option>
                                        <option value="high" <%= a.urgency === 'high' ? 'selected' : '' %>>High</option>
                                    </select>
                                    <label>Post Date:</label>
                                    <input type="datetime-local" name="datePosted" id="datePosted" min="<%= new Date().toISOString().slice(0,16) %>">
                                    
                                    <div class="modal-actions">
                                        <button type="submit" class="submit-btn">Save Changes</button>
                                        <button type="button" class="cancel-btn" onclick="document.getElementById('edit-modal-<%= a._id %>').style.display='none'">Cancel</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</body>
</html>