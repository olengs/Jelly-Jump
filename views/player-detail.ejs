<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= player.username %>'s History — Jelly Jump Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/globalstyle.css">
    <style>
        body {
            background: #1a0a2e;
            color: #fff;
            font-family: 'Pixelify Sans', sans-serif;
            padding: 30px;
            max-width: 900px;
            margin: 0 auto;
        }
        h1 { color: #ff69b4; text-shadow: 0 0 10px #ff69b4; }
        h2 { color: #00d4ff; margin-top: 30px; }

        .player-stats {
            display: flex;
            gap: 20px;
            margin: 20px 0;
            flex-wrap: wrap;
        }
        .stat-card {
            background: #2d0a4e;
            border: 1px solid #ff69b440;
            border-radius: 8px;
            padding: 14px 24px;
            text-align: center;
            min-width: 120px;
        }
        .stat-card .val { font-size: 28px; color: #ff69b4; }
        .stat-card .lbl { font-size: 11px; color: #aaa; margin-top: 4px; }

        table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        th { background: #2d0a4e; color: #ff69b4; padding: 10px; border: 1px solid #ff69b440; text-align: left; }
        td { padding: 10px; border: 1px solid #ffffff20; vertical-align: middle; }
        tr:hover td { background: #ffffff08; }

        .btn {
            font-family: 'Pixelify Sans', sans-serif;
            padding: 6px 14px;
            border: none;
            cursor: pointer;
            font-size: 13px;
            border-radius: 4px;
            text-decoration: none;
            display: inline-block;
        }
        .btn-blue  { background: #00d4ff; color: #1a0a2e; }
        .btn-red   { background: #ff4466; color: #fff; }
        .btn-pink  { background: #ff69b4; color: #1a0a2e; }
        .btn:hover { opacity: 0.85; }

        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: #000000aa;
            z-index: 100;
            justify-content: center;
            align-items: center;
        }
        .modal-overlay.active { display: flex; }
        .modal {
            background: #1a0a2e;
            border: 2px solid #ff69b4;
            border-radius: 10px;
            padding: 30px;
            width: 360px;
            box-shadow: 0 0 30px #ff69b440;
        }
        .modal h3 { color: #ff69b4; margin-top: 0; }
        .modal label { display: block; margin-bottom: 5px; color: #00d4ff; font-size: 13px; }
        .modal input {
            width: 100%; padding: 8px 12px; margin-bottom: 14px;
            background: #2d0a4e; border: 1px solid #ff69b460;
            border-radius: 4px; color: #fff;
            font-family: 'Pixelify Sans', sans-serif;
            font-size: 14px; box-sizing: border-box;
        }
        .modal input:focus { outline: none; border-color: #ff69b4; }
        .modal-actions { display: flex; gap: 10px; margin-top: 6px; }

        .error-list {
            background: #ff446620; border: 1px solid #ff4466;
            border-radius: 6px; padding: 8px 14px; margin-bottom: 16px;
            list-style: none;
        }
        .error-list li { color: #ff8888; font-size: 13px; }
        .error-list li::before { content: '⚠ '; }

        .actions { display: flex; gap: 8px; }
        .actions form { display: inline; }
    </style>
</head>
<body>

    <h1>🎮 <%= player.username %>'s Profile</h1>
    <p><a href="/admin" style="color:#00d4ff;">← Back to Dashboard</a></p>

    <% if (errors && errors.length > 0) { %>
    <ul class="error-list">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
    </ul>
    <% } %>

    <!-- Player Stats -->
    <div class="player-stats">
        <div class="stat-card">
            <div class="val"><%= player.highScore %></div>
            <div class="lbl">HIGH SCORE</div>
        </div>
        <div class="stat-card">
            <div class="val"><%= player.totalGamesPlayed %></div>
            <div class="lbl">GAMES PLAYED</div>
        </div>
        <div class="stat-card">
            <div class="val"><%= new Date(player.createdAt).toLocaleDateString() %></div>
            <div class="lbl">JOINED</div>
        </div>
        <div class="stat-card">
            <div class="val"><%= player.email %></div>
            <div class="lbl">EMAIL</div>
        </div>
    </div>

    <h2>📋 Game History</h2>

    <% if (player.gameHistory.length === 0) { %>
        <p style="color:#aaa;">No game history recorded.</p>
    <% } else { %>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Score</th>
                <th>Level</th>
                <th>Duration (s)</th>
                <th>Played At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% player.gameHistory.forEach((entry, i) => { %>
            <tr>
                <td><%= i + 1 %></td>
                <td style="color:#ff69b4;"><%= entry.score %></td>
                <td><%= entry.level %></td>
                <td><%= entry.duration %></td>
                <td><%= new Date(entry.playedAt).toLocaleString() %></td>
                <td class="actions">
                    <!-- Edit button triggers modal -->
                    <button class="btn btn-blue"
                        onclick="openEditModal(
                            '<%= entry._id %>',
                            <%= entry.score %>,
                            <%= entry.level %>,
                            <%= entry.duration %>
                        )">Edit</button>

                    <!-- Delete form -->
                    <form action="/admin/players/<%= player._id %>/history/<%= entry._id %>/delete"
                          method="POST"
                          onsubmit="return confirm('Delete this game entry?')">
                        <button type="submit" class="btn btn-red">Delete</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    <% } %>

    <!-- ── Edit Modal ───────────────────────────────────── -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <h3>✏️ Edit Game Entry</h3>
            <form id="editForm" method="POST" action="">
                <label for="editScore">Score</label>
                <input type="number" id="editScore" name="score" min="0" required>

                <label for="editLevel">Level</label>
                <input type="number" id="editLevel" name="level" min="1" required>

                <label for="editDuration">Duration (seconds)</label>
                <input type="number" id="editDuration" name="duration" min="0" required>

                <div class="modal-actions">
                    <button type="submit" class="btn btn-pink">Save</button>
                    <button type="button" class="btn" style="background:#555;color:#fff;"
                            onclick="closeEditModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openEditModal(entryId, score, level, duration) {
            document.getElementById('editForm').action =
                '/admin/players/<%= player._id %>/history/' + entryId + '/edit';
            document.getElementById('editScore').value = score;
            document.getElementById('editLevel').value = level;
            document.getElementById('editDuration').value = duration;
            document.getElementById('editModal').classList.add('active');
        }
        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
        }
        // Close modal on overlay click
        document.getElementById('editModal').addEventListener('click', function(e) {
            if (e.target === this) closeEditModal();
        });
    </script>

</body>
</html>
