<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= announcement ? 'Edit' : 'New' %> Announcement — Jelly Jump</title>
    <link href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/globalstyle.css">
    <style>
        body {
            background: #1a0a2e;
            color: #fff;
            font-family: 'Pixelify Sans', sans-serif;
            padding: 30px;
            max-width: 600px;
            margin: 0 auto;
        }
        h1 { color: #ff69b4; text-shadow: 0 0 10px #ff69b4; }

        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 6px; color: #00d4ff; font-size: 14px; }

        input[type="text"], textarea, select {
            width: 100%;
            padding: 10px 14px;
            background: #2d0a4e;
            border: 2px solid #ff69b460;
            border-radius: 6px;
            color: #fff;
            font-family: 'Pixelify Sans', sans-serif;
            font-size: 14px;
            box-sizing: border-box;
        }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #ff69b4;
            box-shadow: 0 0 8px #ff69b440;
        }
        textarea { resize: vertical; min-height: 100px; }

        .btn {
            font-family: 'Pixelify Sans', sans-serif;
            padding: 10px 24px;
            border: none;
            cursor: pointer;
            font-size: 15px;
            border-radius: 4px;
            text-decoration: none;
            display: inline-block;
        }
        .btn-pink { background: #ff69b4; color: #1a0a2e; }
        .btn-gray { background: #555; color: #fff; margin-left: 10px; }
        .btn:hover { opacity: 0.85; }

        .error-list {
            background: #ff446620;
            border: 1px solid #ff4466;
            border-radius: 6px;
            padding: 10px 16px;
            margin-bottom: 20px;
            list-style: none;
        }
        .error-list li { color: #ff8888; margin: 4px 0; }
        .error-list li::before { content: '⚠ '; }

        .char-count { font-size: 11px; color: #aaa; text-align: right; margin-top: 4px; }
    </style>
</head>
<body>

    <h1><%= announcement ? '✏️ Edit Announcement' : '📢 New Announcement' %></h1>
    <p><a href="/admin" style="color:#00d4ff;">← Back to Dashboard</a></p>

    <% if (errors && errors.length > 0) { %>
    <ul class="error-list">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
    </ul>
    <% } %>

    <form method="POST"
          action="<%= announcement ? '/admin/announcements/' + announcement._id + '/edit' : '/admin/announcements' %>">

        <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title"
                   maxlength="100"
                   value="<%= announcement ? announcement.title : '' %>"
                   placeholder="e.g. Server Maintenance Tonight"
                   oninput="updateCount('title', 'titleCount', 100)">
            <div class="char-count"><span id="titleCount">0</span>/100</div>
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message"
                      maxlength="1000"
                      placeholder="Write your announcement here..."
                      oninput="updateCount('message', 'msgCount', 1000)"><%= announcement ? announcement.message : '' %></textarea>
            <div class="char-count"><span id="msgCount">0</span>/1000</div>
        </div>

        <div class="form-group">
            <label for="urgency">Urgency</label>
            <select id="urgency" name="urgency">
                <option value="low"    <%= (!announcement || announcement.urgency === 'low')    ? 'selected' : '' %>>🟢 Low</option>
                <option value="medium" <%= (announcement && announcement.urgency === 'medium')  ? 'selected' : '' %>>🟡 Medium</option>
                <option value="high"   <%= (announcement && announcement.urgency === 'high')    ? 'selected' : '' %>>🔴 High</option>
            </select>
        </div>

        <button type="submit" class="btn btn-pink">
            <%= announcement ? 'Save Changes' : 'Post Announcement' %>
        </button>
        <a href="/admin" class="btn btn-gray">Cancel</a>
    </form>

    <script>
        function updateCount(fieldId, countId, max) {
            const len = document.getElementById(fieldId).value.length;
            document.getElementById(countId).textContent = len;
        }
        // Init counts on load
        updateCount('title',   'titleCount', 100);
        updateCount('message', 'msgCount',   1000);
    </script>

</body>
</html>
