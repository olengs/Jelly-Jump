<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Friends List - Jelly Jump</title>
    <link rel="stylesheet" href="/style/globalstyle.css">
    <link rel="stylesheet" href="/style/friends.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="friends-wrapper">
        <h1>👾 Friends</h1>

        <!-- incoming friend requests -->
        <% if (incomingRequests && incomingRequests.length > 0) { %>
            <h2>📬 Friend Requests</h2>
            <% incomingRequests.forEach(requester => { %>
                <div class="friend-card" style="max-width: 400px; margin: 8px auto;">
                    <p class="friend-name"><%= requester %></p>

                    <form action="/acceptfriend" method="post" style="display:inline;">
                        <input type="hidden" name="requesterName" value="<%= requester %>">
                        <button type="submit" class="btn">Accept</button>
                    </form>

                    <form action="/rejectfriend" method="post" style="display:inline;">
                        <input type="hidden" name="requesterName" value="<%= requester %>">
                        <button type="submit" class="btn">Reject</button>
                    </form>
                </div>
            <% }); %>
            <br>
        <% } %>

        <% if (error){ %>
            <p class="error-msg"><%= error %></p>
        <% } %>
        <br><br>

        <!-- search friend AND THEN ADD FRIEND -->
        <form action="friendslist" method="get" class="add-friend-form">
            <label for="friendName">Name of Friend:</label>
            <input type="text" id="friendName" name="search" placeholder="Search username..." value="<%= typeof search !== undefined ? search : '' %>">
            <br><br>
            
            <button type="submit">Find</button>
        </form>

        <% if (typeof result !== undefined) {result.forEach(r => { %>
            <div class="friend-card" style="max-width: 400px; align-items: center; margin: 0 auto">
                <p class="friend-name"><%= r.username %></p>                   
                <a class="btn" href="/profile/view/<%= r._id %>">View Profile</a>

                <% if (sentRequests.includes(r.username)) { %>
                    <button class="btn" disabled style="opacity:0.5; cursor:not-allowed;">Sent</button>
                <% } else if (incomingRequests.includes(r.username)) { %>
                    <form action="/acceptfriend" method="post" style="display:inline;">
                        <input type="hidden" name="requesterName" value="<%= r.username %>">
                        <button type="submit" class="btn">Accept</button>
                    </form>
                <% } else { %>
                    <form action="/friendslist" method="post" style="display:inline;">
                        <input type="hidden" name="friendName" value="<%= r.username %>">
                        <button type="submit" class="btn">+ Add</button>
                    </form>
                <% } %>
            </div>
            <br>
        <% }); } %>
        <br>

        <h2>Friends List</h2>

        <% if (friendsIdlist.length < 1) { %>
            <p class="empty-msg">Add new friends!</p>
        <% } %>

        <% friendsIdlist.forEach(f => { %>
            <div class="friend-card">
                <p class="friend-name"><%= f.name %></p> 

                <a class="btn" href="/profile/view/<%= f.id %>"> View Profile</a>

                <form action="/deletefriend" method="post">
                    <input type="hidden" name='friendName' value="<%= f.name %>"> 
                    <button type="submit" class="btn">Delete</button>
                </form>
            </div>
        <% }); %>

        <br><br><br>

    </div>
</body>
</html>