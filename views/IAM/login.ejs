<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Astro Jelly Login</title>
    <link rel="stylesheet" href="style/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>
<body>
    <div class="scanlines"></div>

    <div class="login-container">
        <div class="mascot-container">
            <svg viewBox="0 0 10 8" width="80" height="64" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <style>
                    .j-body { fill: #ff77a8; }
                    .j-light { fill: #ffb6c1; }
                    .j-eye-w { fill: #ffffff; }
                    .j-eye-b { fill: #22123d; }
                    .j-blush { fill: #ff3377; }
                </style>
                <rect x="3" y="0" width="4" height="1" class="j-light" />
                <rect x="2" y="1" width="6" height="1" class="j-body" />
                <rect x="3" y="1" width="2" height="1" class="j-light" />
                <rect x="1" y="2" width="8" height="1" class="j-body" />
                <rect x="2" y="2" width="1" height="1" class="j-eye-w" />
                <rect x="7" y="2" width="1" height="1" class="j-eye-w" />
                <rect x="1" y="3" width="8" height="1" class="j-body" />
                <rect x="2" y="3" width="1" height="1" class="j-eye-b" />
                <rect x="7" y="3" width="1" height="1" class="j-eye-b" />
                <rect x="0" y="4" width="10" height="1" class="j-body" />
                <rect x="1" y="4" width="1" height="1" class="j-blush" />
                <rect x="8" y="4" width="1" height="1" class="j-blush" />
                <rect x="0" y="5" width="10" height="1" class="j-body" />
                <rect x="0" y="6" width="2" height="1" class="j-body" />
                <rect x="3" y="6" width="1" height="1" class="j-body" />
                <rect x="6" y="6" width="1" height="1" class="j-body" />
                <rect x="8" y="6" width="2" height="1" class="j-body" />
                <rect x="0" y="7" width="1" height="1" class="j-body" />
                <rect x="4" y="7" width="2" height="1" class="j-body" />
                <rect x="9" y="7" width="1" height="1" class="j-body" />
            </svg>
        </div>

        <h1>ASTRO JELLIES</h1>
        <p class="subtitle">SQUISHY INVASION PROTOCOL</p>
        
        <form onsubmit="event.preventDefault();" action="/auth/login" method="post">
            <div class="input-group">
                <label for="username">JELLY ID:</label>
                <input type="text" id="username" placeholder="ENTER ALIAS" required>
            </div>
            
            <div class="input-group">
                <label for="password">PASSWORD:</label>
                <div class="password-wrapper">
                    <input type="password" id="password" placeholder="****" required>
                    <button type="button" class="preview"><i class="fa-regular fa-eye visible-icon" onclick="toggleDisplay('password')"></i></button>
                </div>
            </div>
            
            <button type="submit" class="login-btn">BOOP TO ENTER</button>
        </form>

        <p class="subtitle linktext">
            NOT PART OF THE CREW YET?<br><br>
            <u><a href="/signup" class="links"> SIGN UP HERE </a></u>
        </p>
    </div>
</body>
</html>

<script>
function toggleDisplay(id) {
    var x = document.getElementById(id);
    if (x.type === "password") {
        x.type = "text"; // or "inline", "inline-block", etc., depending on desired layout
    } else {
        x.type = "password";
    }
}
</script>