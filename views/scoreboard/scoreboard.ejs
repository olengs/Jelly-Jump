<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard - Jelly Jump</title>
    <link rel="stylesheet" href="/style/globalstyle.css">
    <link rel="stylesheet" href="/style/scoreboard.css">
</head>
<body>
    <div class="scoreboard-wrapper">
        <h1>🏆 Leaderboard</h1>

        <!-- Tabs -->
        <div class="tab-bar">
            <button class="tab-btn active" onclick="switchTab('global')">🌍 Global</button>
            <button class="tab-btn" onclick="switchTab('friends')">👥 Friends</button>
        </div>

        <!-- Filters -->
        <div class="filters">
            <input type="text" id="search-input" placeholder="Search username..." oninput="applyFilters()" />
            <select id="sort-select" onchange="applyFilters()">
                <option value="desc">High Score ↓</option>
                <option value="asc">High Score ↑</option>
            </select>
        </div>

        <!-- Global Tab -->
        <div id="tab-global" class="tab-content">
            <% if (topTen && topTen.length > 0) { %>
                <table id="global-table">
                    <thead>
                        <tr>
                            <% if (user && user.role === 'admin') { %>
                                <th>Actions</th>
                            <% } %>
                            <th>Rank</th>
                            <th>Player</th>
                            <th>High Score</th>
                            <th>Games Played</th>
                        </tr>
                    </thead>
                    <tbody id="global-tbody">
                        <% topTen.forEach((entry, index) => { %>
                        <tr class="<%= (user && entry.username === user.username) ? 'you-row' : '' %>"
                            data-username="<%= entry.username %>"
                            data-score="<%= entry.highscore %>">
                            <% if (user && user.role === 'admin') { %>
                                <td>
                                    <form action="/scoreboard/delete/<%= entry.playerId %>" method="POST" onsubmit="return confirm('Delete this entry?')">
                                        <button type="submit" class="delete-btn">Delete</button>
                                    </form>
                                </td>
                            <% } %>
                            <td class="rank-cell"><%= index + 1 %></td>
                            <td>
                                <%= entry.username %>
                                <% if (user && entry.username === user.username) { %>
                                    <span class="you-tag">(you)</span>
                                <% } %>
                            </td>
                            <td><%= entry.highscore %></td>
                            <td><%= entry.gamesPlayed %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            <p id="global-empty" style="display:none;">No results found.</p>
            <% } else { %>
                <p>No scores yet. Be the first to play!</p>
            <% } %>
        </div>

        <!-- Friends Tab -->
        <div id="tab-friends" class="tab-content" style="display:none;">
            <% if (!user) { %>
                <p>Log in to see your friends leaderboard.</p>
            <% } else if (friendsScores && friendsScores.length > 0) { %>
                <table id="friends-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Player</th>
                            <th>High Score</th>
                            <th>Games Played</th>
                        </tr>
                    </thead>
                    <tbody id="friends-tbody">
                        <% friendsScores.forEach((entry, index) => { %>
                        <tr class="<%= entry.username === user.username ? 'you-row' : '' %>"
                            data-username="<%= entry.username %>"
                            data-score="<%= entry.highscore %>">
                            <td class="rank-cell"><%= index + 1 %></td>
                            <td>
                                <%= entry.username %>
                                <% if (entry.username === user.username) { %>
                                    <span class="you-tag">(you)</span>
                                <% } %>
                            </td>
                            <td><%= entry.highscore %></td>
                            <td><%= entry.gamesPlayed %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <p id="friends-empty" style="display:none;">No results found.</p>
            <% } else { %>
                <p>No friends scores yet. Add some friends and start playing!</p>
            <% } %>
        </div>

        <a href="/game" class="play-btn">Play Again</a>
    </div>

    <script src="/scoreboard/scoreboard.js"></script>
</body>
</html>
