<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Game Records</title>
</head>
<body>
    <h1>Game Records</h1>
    
    <% if (error) { %>
        <p><%= error %></p>
    <% } %>

    <% if (history.length === 0) { %>
        <p>No games played yet. Go play!</p>
    <% } else { %>
        <table border="1">
            <tr>
                <th>Date</th>
                <th>Score</th>
                <th>Character</th>
                <th>Currency Earned</th>
                <th>Jumps</th>
                <th>Action</th>
            </tr>

            <% history.forEach(function(entry) { %>
            <tr>
                <td><%= entry.timestamp.toLocaleDateString() %></td>
                <td><%= entry.score %></td>
                <td>Jelly <%= entry.character || '-' %></td>
                <td><%= entry.currencyEarned %></td>
                <td><%= entry.jumps %></td>
                <td>
                    <form action="/history/edit/<%= entry._id %>" method="get">
                        <button type="submit">Edit</button>
                    </form>
                    <form action="/history/delete/<%= entry._id %>" method="post">
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        <% }) %>
        </table>
    <% } %>
</body>
</html>