<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Profile</title>
    <link rel="stylesheet" href="/style/globalstyle.css">
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="centered margin-top-20">
        <h1 class="margin-bot-20"><%= user.username %>'s Profile</h1>
        <p><strong>Username:</strong> <%= user.username %></p><br>
        <p><strong>Email:</strong> <%= user.email %></p><br>
        <p><strong>Bio:</strong> <%= user.bio || 'No bio yet.' %></p><br>

        <% if (user._id === self._id) { %>
            <a href="/profile/edit">Edit Profile</a><br><br>
        <% } %>

        <a href="/profile/history/<%= user._id %>">View Player History</a><br><br>

        <% if (user.role == "sysadmin") { %>
            <a href="/profile/viewall">View All Users</a><br><br>
        <% } %> 

        <form action="/profile/delete" method="post">
            <button type="submit" onclick="return confirm('Are you sure you want to delete your account?')">Delete Account</button>
        </form>
    </div>
</body>
</html>