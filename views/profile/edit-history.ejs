<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Player History</title>
</head>
<body>
    <h1>Edit Player History</h1>
    
    <% if (error) { %>
        <p><%= error %></p>
    <% } %> 

    <form action="/profile/history/edit/<%= record._id %>" method="post">
        <label>Score:</label><br>
        <input type="number" name="score" value="<%= record.score %>" required><br><br>

        <button type="submit">Save Changes</button>
        <a href="/profile/history/<%= record.playerId %>">Cancel</a>
    </form>

</body>
</html>