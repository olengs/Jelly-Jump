<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Jelly Jump | High-Energy Bouncing</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #121212;
            color: white;
            overflow-x: hidden;
        }


        /* --- Hero Section --- */
        .hero {
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: radial-gradient(circle, rgba(0,243,255,0.1) 0%, rgba(18,18,18,1) 70%);
        }

        .hero h1 {
            font-size: 5rem;
            margin-bottom: 1rem;
            background: linear-gradient(to right, #FF4DFF, #00F3FF);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .play-btn {
            padding: 1rem 3rem;
            font-size: 1.5rem;
            background: transparent;
            color: #FF4DFF;
            border: 3px solid #FF4DFF;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.4s;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(255, 77, 255, 0.3);
        }

        .play-btn:hover {
            background: #FF4DFF;
            color: white;
            box-shadow: 0 0 30px #FF4DFF;
            transform: scale(1.05);
        }
    </style>
    <link rel="stylesheet" href="/style/globalstyle.css">
</head>
<body>

    <%- include('partials/navbar') %>

    <div class="hero">
        <h1>Ready to Bounce?</h1>
        <p>Master the jump. Defy the wobble.</p>
        <br>
        <button class="play-btn">START JUMPING</button>
    </div>

</body>
</html>